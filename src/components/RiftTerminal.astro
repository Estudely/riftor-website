---
---

<div class="term-container w-full max-w-3xl mx-auto" id="rift-term">
  <!-- Title bar -->
  <div class="flex items-center justify-between px-3 sm:px-4 py-2 border-b border-void-border bg-void-panel">
    <div class="flex items-center gap-2 sm:gap-3">
      <div class="flex gap-1.5">
        <span class="w-2 h-2 sm:w-2.5 sm:h-2.5 rounded-full bg-[#ff5f57]"></span>
        <span class="w-2 h-2 sm:w-2.5 sm:h-2.5 rounded-full bg-[#febc2e]"></span>
        <span class="w-2 h-2 sm:w-2.5 sm:h-2.5 rounded-full bg-[#28c840]"></span>
      </div>
      <span class="text-[11px] sm:text-[13px] text-rift-dim tracking-wide">riftor · v0.0.2</span>
    </div>
    <div class="rift-stage">
      <span class="text-[10px] text-rift-dim mr-1">[</span>
      <span class="active" id="term-R">R</span><span class="dot">·</span>
      <span class="inactive" id="term-I">I</span><span class="dot">·</span>
      <span class="inactive" id="term-F">F</span><span class="dot">·</span>
      <span class="inactive" id="term-T">T</span>
      <span class="text-[10px] text-rift-dim ml-1">]</span>
    </div>
  </div>

  <!-- Output area -->
  <div class="px-3 sm:px-4 py-3 overflow-y-auto text-[12px] sm:text-[14px] leading-[1.7] term-output" id="term-output" style="height: 300px;">
  </div>

  <!-- Input -->
  <div class="flex items-center px-3 sm:px-4 py-2 sm:py-2.5 border-t border-void-border bg-void-panel">
    <span class="text-rift-amber mr-2 text-[12px] sm:text-[14px] select-none">❯</span>
    <input
      type="text"
      id="term-input"
      class="flex-1 bg-transparent text-[12px] sm:text-[14px] text-rift-text outline-none placeholder-rift-dim caret-rift-amber"
      placeholder="type /help to start"
      autocomplete="off"
      spellcheck="false"
    />
  </div>

  <!-- Status bar -->
  <div class="flex items-center justify-between px-3 sm:px-4 py-1.5 border-t border-void-border text-[10px] sm:text-[11px] text-rift-dim bg-void">
    <div class="flex items-center gap-2 sm:gap-3">
      <span class="flex items-center gap-1"><span class="w-1.5 h-1.5 rounded-full bg-rift-green status-dot"></span> online</span>
      <span>scope: <span id="term-scope-ct" class="text-rift-muted">0</span></span>
      <span>finds: <span id="term-finds-ct" class="text-rift-muted">0</span></span>
    </div>
    <span class="hidden sm:inline">model: <span class="text-rift-muted">anthropic/claude-sonnet-4-6</span></span>
  </div>
</div>

<script>
  const COMMANDS: Record<string, (args: string) => string[]> = {};
  let scopeTargets: string[] = [];
  let findings = 0;
  let currentStage = 'R';

  function c(color: string, text: string): string {
    const map: Record<string, string> = {
      amber: 'color: #e09f3e',
      cyan: 'color: #5eead4',
      rose: 'color: #fb7185',
      danger: 'color: #f87171',
      dim: 'color: #52525b',
      muted: 'color: #a1a1aa',
      green: 'color: #4ade80',
      text: 'color: #d4d4d8',
      bold: 'color: #d4d4d8; font-weight: 600',
    };
    return `<span style="${map[color] || ''}">${text}</span>`;
  }

  COMMANDS['/help'] = () => [
    '',
    c('bold', 'riftor — commands'),
    '',
    `  ${c('amber', '/help')}          show this help`,
    `  ${c('amber', '/clear')}         clear the conversation`,
    `  ${c('amber', '/model [name]')}  show or switch the model`,
    `  ${c('amber', '/stage [R|I|F|T]')} show or set the RIFT stage`,
    `  ${c('amber', '/scope [add <t>]')} manage in/out-of-scope targets`,
    `  ${c('amber', '/findings')}      list recorded findings`,
    `  ${c('amber', '/report')}        write a pentest report`,
    `  ${c('amber', '/tools')}         list available tools`,
    `  ${c('amber', '/lore')}          toggle the rift persona`,
    `  ${c('amber', '/demo')}          run a demo engagement`,
    '',
    `  ${c('dim', 'type anything else to task the agent.')}`,
    `  ${c('dim', 'try: "enumerate the web host and look for low-hanging fruit"')}`,
    '',
  ];

  COMMANDS['/tools'] = () => [
    '',
    c('bold', 'tools'),
    '',
    `  ${c('amber', 'bash')}           ${c('danger', '⚠')} run a shell command`,
    `  ${c('amber', 'read')}           read a file`,
    `  ${c('amber', 'write')}          ${c('danger', '⚠')} create or overwrite a file`,
    `  ${c('amber', 'edit')}           ${c('danger', '⚠')} replace a string in a file`,
    `  ${c('amber', 'grep')}           search file contents`,
    `  ${c('amber', 'glob')}           find files by pattern`,
    `  ${c('amber', 'webfetch')}       fetch a URL`,
    `  ${c('amber', 'scope_list')}     show current scope`,
    `  ${c('amber', 'record_service')} log a host/port/service`,
    `  ${c('amber', 'record_finding')} log a vulnerability`,
    `  ${c('amber', 'set_stage')}      set the RIFT stage`,
    '',
    `  ${c('dim', '⚠ = needs operator approval')}`,
    '',
  ];

  COMMANDS['/scope'] = (args: string) => {
    if (!args) {
      if (scopeTargets.length === 0) {
        return [c('dim', 'scope · enforce on · in: (none)'), ''];
      }
      return [
        `scope · enforce ${c('green', 'on')} · in: ${c('cyan', scopeTargets.join(', '))}`,
        '',
      ];
    }
    const parts = args.split(/\s+/);
    const sub = parts[0];
    const rest = parts.slice(1);
    if (sub === 'add' && rest.length > 0) {
      rest.forEach(t => { if (!scopeTargets.includes(t)) scopeTargets.push(t); });
      updateScopeCt();
      return [c('dim', `in-scope += ${rest.join(', ')}`), ''];
    }
    if (sub === 'clear') {
      scopeTargets = [];
      updateScopeCt();
      return [c('dim', 'scope cleared'), ''];
    }
    return [c('dim', 'usage: /scope [add <target>|clear]'), ''];
  };

  COMMANDS['/stage'] = (args: string) => {
    const valid: Record<string, string> = { R: 'Recon', I: 'Intrusion', F: 'Foothold', T: 'Takeover' };
    if (!args) {
      return [
        `stage: ${c('amber', currentStage)} (${valid[currentStage]})`,
        c('dim', 'R Recon · I Intrusion · F Foothold · T Takeover'),
        '',
      ];
    }
    const letter = args.trim().toUpperCase();
    if (valid[letter]) {
      currentStage = letter;
      updateStageDisplay();
      return [`stage → ${c('amber', letter)} (${valid[letter]})`, ''];
    }
    return [c('danger', `unknown stage: ${args}`), ''];
  };

  COMMANDS['/findings'] = () => {
    if (findings === 0) {
      return [c('dim', 'no findings recorded yet'), '', c('dim', 'try /demo to simulate an engagement'), ''];
    }
    return [
      '',
      c('bold', 'findings'),
      '',
      `  1. ${c('danger', '[CRITICAL]')} SQL injection in /api/users — ${c('muted', '10.0.0.5')}`,
      `     ${c('dim', 'CVSS:3.1/AV:N/AC:L/PR:N/UI:N/S:U/C:H/I:H/A:H → 9.8')}`,
      `  2. ${c('rose', '[HIGH]')}     Exposed admin panel — ${c('muted', '10.0.0.5:8080')}`,
      `     ${c('dim', 'CVSS:3.1/AV:N/AC:L/PR:N/UI:N/S:U/C:H/I:L/A:N → 8.2')}`,
      `  3. ${c('amber', '[MEDIUM]')}   CORS misconfiguration — ${c('muted', 'app.example.com')}`,
      `     ${c('dim', 'CVSS:3.1/AV:N/AC:L/PR:N/UI:R/S:U/C:L/I:L/A:N → 5.4')}`,
      `  4. ${c('cyan', '[LOW]')}      Missing security headers — ${c('muted', 'example.com')}`,
      '',
    ];
  };

  COMMANDS['/report'] = () => {
    if (findings === 0) {
      return [c('dim', 'no findings to report — run /demo first'), ''];
    }
    return [
      c('dim', 'generating report...'),
      `report written: ${c('cyan', '.riftor/reports/report-20260602-1430.md')}`,
      `report written: ${c('cyan', '.riftor/reports/report-20260602-1430.html')}`,
      '',
    ];
  };

  COMMANDS['/model'] = (args: string) => {
    if (!args) {
      return [`model: ${c('muted', 'anthropic/claude-sonnet-4-6')}`, ''];
    }
    return [`model → ${c('amber', args.trim())}`, ''];
  };

  COMMANDS['/lore'] = () => {
    return [c('dim', 'lore engaged — the void whispers'), ''];
  };

  COMMANDS['/clear'] = () => {
    setTimeout(() => {
      const output = document.getElementById('term-output');
      if (output) output.innerHTML = '';
    }, 50);
    return [];
  };

  COMMANDS['/demo'] = () => {
    scopeTargets = ['10.0.0.0/24', 'example.com'];
    currentStage = 'R';
    findings = 4;
    updateScopeCt();
    updateFindsCt();
    updateStageDisplay();

    const lines = [
      '',
      c('dim', '── demo engagement ──────────────────────'),
      '',
      `${c('amber', '❯')} /scope add 10.0.0.0/24 example.com`,
      c('dim', 'in-scope += 10.0.0.0/24, example.com'),
      '',
      `${c('amber', '❯')} ${c('muted', '"enumerate the web hosts and look for low-hanging fruit"')}`,
      '',
      `  ${c('cyan', '⛏ bash')}  ${c('dim', 'nmap -sV -sC 10.0.0.0/24')}`,
    ];

    setTimeout(() => {
      appendLines([
        `  ${c('rose', 'permission required · bash')}`,
        `  ${c('dim', 'nmap -sV -sC 10.0.0.0/24')}`,
        `  ${c('green', '[ Allow once (a) ]')} ${c('dim', '[ Allow session (s) ] [ Deny (esc) ]')}`,
        `  ${c('green', '→ allowed')}`,
        '',
        `  ${c('dim', 'PORT     STATE SERVICE  VERSION')}`,
        `  ${c('text', '22/tcp   open  ssh      OpenSSH 8.9')}`,
        `  ${c('text', '80/tcp   open  http     nginx 1.24.0')}`,
        `  ${c('text', '443/tcp  open  https    nginx 1.24.0')}`,
        `  ${c('text', '8080/tcp open  http     Tomcat 9.0.73')}`,
      ]);
    }, 800);

    setTimeout(() => {
      currentStage = 'I';
      updateStageDisplay();
      appendLines([
        '',
        `  ${c('dim', 'stage → I (Intrusion)')}`,
        '',
        `  ${c('cyan', '⛏ bash')}  ${c('dim', 'nuclei -u http://10.0.0.5 -severity critical,high')}`,
        `  ${c('green', '→ allowed')}`,
        '',
        `  ${c('danger', '[critical]')} sql-injection /api/users?id=1 ${c('dim', '— 10.0.0.5')}`,
        `  ${c('rose', '[high]')}     exposed-admin-panel ${c('dim', '— 10.0.0.5:8080')}`,
      ]);
    }, 2200);

    setTimeout(() => {
      appendLines([
        '',
        `  ${c('dim', '── recording findings ──')}`,
        `  ${c('cyan', '⛏ record_finding')}  ${c('danger', 'CRITICAL')} SQL injection in /api/users`,
        `  ${c('cyan', '⛏ record_finding')}  ${c('rose', 'HIGH')} Exposed admin panel`,
        `  ${c('cyan', '⛏ record_finding')}  ${c('amber', 'MEDIUM')} CORS misconfiguration`,
        `  ${c('cyan', '⛏ record_finding')}  ${c('cyan', 'LOW')} Missing security headers`,
        '',
        c('dim', 'findings: 4 recorded · /findings to review · /report to generate'),
        '',
      ]);
      updateFindsCt();
    }, 3400);

    return lines;
  };

  function updateScopeCt() {
    const el = document.getElementById('term-scope-ct');
    if (el) el.textContent = String(scopeTargets.length);
  }
  function updateFindsCt() {
    const el = document.getElementById('term-finds-ct');
    if (el) el.textContent = String(findings);
  }
  function updateStageDisplay() {
    ['R', 'I', 'F', 'T'].forEach(s => {
      const el = document.getElementById(`term-${s}`);
      if (el) {
        el.className = s === currentStage ? 'active' : 'inactive';
      }
    });
  }

  function appendLines(lines: string[]) {
    const output = document.getElementById('term-output');
    if (!output) return;
    lines.forEach((line, i) => {
      const div = document.createElement('div');
      div.className = 'term-line';
      div.style.animationDelay = `${i * 30}ms`;
      div.innerHTML = line || '&nbsp;';
      output.appendChild(div);
    });
    output.scrollTop = output.scrollHeight;
  }

  function processCommand(raw: string) {
    const output = document.getElementById('term-output');
    if (!output) return;

    const echo = document.createElement('div');
    echo.innerHTML = `<span style="color: #e09f3e">❯</span> <span style="color: #d4d4d8">${raw}</span>`;
    output.appendChild(echo);

    const trimmed = raw.trim();
    const spaceIdx = trimmed.indexOf(' ');
    const cmd = spaceIdx > -1 ? trimmed.slice(0, spaceIdx) : trimmed;
    const args = spaceIdx > -1 ? trimmed.slice(spaceIdx + 1).trim() : '';

    if (COMMANDS[cmd]) {
      const lines = COMMANDS[cmd](args);
      appendLines(lines);
    } else if (trimmed.startsWith('/')) {
      appendLines([c('dim', `unknown command: ${cmd} — try /help`), '']);
    } else if (trimmed.length > 0) {
      appendLines([
        '',
        c('dim', 'opening rift…'),
      ]);
      setTimeout(() => {
        appendLines([
          '',
          `I'll help with that. First, let me check the current scope.`,
          '',
          `${c('cyan', '⛏ scope_list')}`,
          scopeTargets.length > 0
            ? c('dim', `in-scope: ${scopeTargets.join(', ')}`)
            : c('dim', 'no scope defined — set scope with /scope add <target> before proceeding'),
          '',
          scopeTargets.length > 0
            ? `Ready to proceed. I'll start with passive reconnaissance on the in-scope targets.`
            : c('muted', 'Set a scope first, then task me with what you need.'),
          '',
        ]);
      }, 600);
    }

    output.scrollTop = output.scrollHeight;
  }

  const input = document.getElementById('term-input') as HTMLInputElement;
  const output = document.getElementById('term-output');

  if (output) {
    const welcome = [
      c('amber', 'riftor') + c('dim', ' · v0.0.2 · offensive-security AI agent'),
      c('dim', 'find the rift. open it. cross through.'),
      '',
      c('dim', 'type /help for commands · /demo for a simulated engagement'),
      '',
    ];
    welcome.forEach((line, i) => {
      const div = document.createElement('div');
      div.className = 'term-line';
      div.style.animationDelay = `${i * 60}ms`;
      div.innerHTML = line || '&nbsp;';
      output.appendChild(div);
    });
  }

  let history: string[] = [];
  let histIdx = -1;

  input?.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Enter') {
      const val = input.value;
      if (val.trim()) {
        history.unshift(val);
        histIdx = -1;
        processCommand(val);
        input.value = '';
      }
    }
    if (e.key === 'ArrowUp') {
      e.preventDefault();
      if (histIdx < history.length - 1) {
        histIdx++;
        input.value = history[histIdx];
      }
    }
    if (e.key === 'ArrowDown') {
      e.preventDefault();
      if (histIdx > 0) {
        histIdx--;
        input.value = history[histIdx];
      } else {
        histIdx = -1;
        input.value = '';
      }
    }
  });

  document.getElementById('rift-term')?.addEventListener('click', () => {
    input?.focus();
  });
</script>
