---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'riftor — offensive-security AI agent for your terminal',
  description = 'An open-source offensive-security AI agent that lives in your terminal. Find the rift. Open it. Cross through.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#08080c" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="riftor" />
    <meta property="og:url" content="https://riftor.dev" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600;700&family=Silkscreen:wght@400;700&display=swap" rel="stylesheet" />

    <title>{title}</title>
  </head>
  <body class="noise">
    <slot />
    <script>
      document.querySelectorAll('.reveal').forEach(el => {
        new IntersectionObserver(([e]) => {
          if (e.isIntersecting) el.classList.add('visible');
        }, { threshold: 0.1 }).observe(el);
      });
      // Animate XP bars on scroll
      document.querySelectorAll('.xp-bar').forEach(bar => {
        new IntersectionObserver(([e]) => {
          if (e.isIntersecting) {
            const target = (bar as HTMLElement).dataset.xp || '0';
            (bar as HTMLElement).style.setProperty('--xp', target + '%');
          }
        }, { threshold: 0.5 }).observe(bar);
      });
    </script>
  </body>
</html>
